# =============================================================================
# FloodNav — Environment Variables
# Copy to .env — NEVER commit .env to git
# =============================================================================

# --- FRONTEND (Vercel) -------------------------------------------------------
# Map SDK key — safe to expose in browser (scope-limited)
VITE_GISTDA_MAP_KEY=

# Leave empty when using vercel.json rewrite (recommended).
# Set to Railway API URL only if bypassing vercel.json (e.g. direct fetch fallback).
VITE_API_BASE_URL=

# --- BACKEND API (Railway — Node.js) ----------------------------------------
NODE_ENV=production
PORT=3001
# Vercel frontend URL — used for CORS allowlist
FRONTEND_ORIGIN=https://YOUR-APP.vercel.app

# Routing: 'local' = use Railway Python service (default), 'osrm' = skip local graph
ROUTING_ENGINE=local
ROUTING_SERVICE_URL=https://YOUR-ROUTING-SERVICE.up.railway.app

# GISTDA Open Data API — backend only, never expose to frontend
GISTDA_API_KEY=

# Thai Meteorological Department NWP JWT
TMD_TOKEN=

# Typhoon AI (OpenAI-compatible)
TYPHOON_API_KEY=

# Supabase — CCTV detections from Jetson Nano
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# --- ROUTING SERVICE (Railway — Python) -------------------------------------
# Railway injects PORT automatically — do not set manually on Railway
MAX_ROUTE_COUNT=3
MEMORY_LIMIT_GB=5
