{
  "name": "geo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:backend": "node server.js",
    "routing": "gunicorn --bind 0.0.0.0:${PORT:-3002} --workers 1 --timeout 120 scripts.routing_service:app",
    "start": "concurrently --names \"API,UI\" --prefix-colors \"blue,green\" \"node server.js\" \"vite\"",
    "start:local": "concurrently --names \"API,ROUTING,UI\" --prefix-colors \"blue,yellow,green\" \"cross-env ROUTING_ENGINE=local node server.js\" \"python3 scripts/routing_service.py\" \"vite\"",
    "start:local:3": "concurrently --names \"API,ROUTING,UI\" --prefix-colors \"blue,yellow,green\" \"cross-env ROUTING_ENGINE=local node server.js\" \"cross-env MAX_ROUTE_COUNT=3 python3 scripts/routing_service.py\" \"vite\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "node-fetch": "^3.3.2",
    "openai": "^6.39.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^5.4.10"
  }
}
